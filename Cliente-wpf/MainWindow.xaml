<Window x:Class="ControlLab.ClienteWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ControlLab"
        Height="941"
        Width="1672"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="#F7F9FB"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#007C78"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#082B2D"/>
        <SolidColorBrush x:Key="PrimaryLight" Color="#E8F6F6"/>
        <SolidColorBrush x:Key="Surface" Color="#F8FAFB"/>
        <SolidColorBrush x:Key="Card" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMain" Color="#0C272A"/>
        <SolidColorBrush x:Key="TextSoft" Color="#66717E"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#CBD5DB"/>
        <SolidColorBrush x:Key="Danger" Color="#8B0000"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonBorder" CornerRadius="18" BorderBrush="#0A837D" BorderThickness="1" SnapsToDevicePixels="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0C948E" Offset="0"/>
                                        <GradientStop Color="#087F79" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0A6F6A" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                                </Border.Effect>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#17A59F"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.97"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007C78"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Width" Value="230"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18" BorderBrush="#0D8E89" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#08756F" BlurRadius="16" ShadowDepth="0" Opacity="0.24"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18" BorderBrush="#A30B0B" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#5F0000" BlurRadius="16" ShadowDepth="0" Opacity="0.22"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#E2E9EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1B3D4A" BlurRadius="18" ShadowDepth="0" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F1F4F6">
        <Viewbox Stretch="UniformToFill">
            <Border Width="1672" Height="941" Background="#F7F9FB" CornerRadius="28" ClipToBounds="True" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="641"/>
                        <ColumnDefinition Width="1031"/>
                    </Grid.ColumnDefinitions>

                    <!-- Panel izquierdo del diseño aprobado -->
                    <Image Grid.Column="0" Source="/Assets/login_left_panel.png" Stretch="Fill"/>

                    <!-- Panel derecho limpio y sobrio -->
                    <Border Grid.Column="1">
                        <Border.Background>
                            <RadialGradientBrush Center="0.55,0.40" RadiusX="0.84" RadiusY="0.84" GradientOrigin="0.55,0.35">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FBFCFD" Offset="0.62"/>
                                <GradientStop Color="#F2F5F7" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>

                        <Canvas Width="1031" Height="941">
                            <!-- Sin controles decorativos de ventana -->

                            <!-- LOGIN -->
                            <Canvas x:Name="PanelLogin" Width="620" Height="730" Canvas.Left="205" Canvas.Top="82">
                                <!-- Badge -->
                                <Border Canvas.Left="183" Canvas.Top="4" Width="212" Height="40" CornerRadius="14" Background="#E8F5F4">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE785;" FontSize="18" Foreground="#0A8A84" Margin="0,0,10,0"/>
                                        <TextBlock Text="CONTROL DE ACCESO" FontSize="14" FontWeight="Bold" Foreground="#0A8A84"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Canvas.Left="0" Canvas.Top="76" Width="620" Text="Uso de Computadoras" FontSize="44" FontWeight="ExtraBold" Foreground="#102D30" TextAlignment="Center"/>
                                <TextBlock Canvas.Left="0" Canvas.Top="134" Width="620" Text="Laboratorios y biblioteca institucional" FontSize="20" FontWeight="SemiBold" Foreground="#73808B" TextAlignment="Center"/>

                                <!-- Campo cédula -->
                                <Border Canvas.Left="0" Canvas.Top="183" Width="580" Height="70" Background="#FCFDFD" CornerRadius="18" BorderBrush="#D9E2E7" BorderThickness="1.2" Padding="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="75"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="28" Foreground="#7A8792" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="TxtCedula" Width="480" Height="68" HorizontalAlignment="Left" FontSize="24" FontWeight="SemiBold" BorderThickness="0" Background="Transparent" Foreground="#0C272A" MaxLength="10" VerticalContentAlignment="Center" Padding="0,0,0,2" PreviewTextInput="TxtCedula_PreviewTextInput"/>
                                            <TextBlock x:Name="TxtPlaceholder" Text="Ingrese su cédula sin guion" Width="480" FontSize="21" FontWeight="SemiBold" Foreground="#77838D" VerticalAlignment="Center" IsHitTestVisible="False" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Botón ingresar -->
                                <Button x:Name="BtnIngresar" Canvas.Left="0" Canvas.Top="276" Width="580" Height="64" Style="{StaticResource PrimaryButtonStyle}" Click="BtnIngresar_Click">
                                    <Grid Width="580" Height="64">
                                        <TextBlock Text="Ingresar" FontSize="22" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,18,0"/>
                                        <Border Width="44" Height="44" CornerRadius="14" Background="#22FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0">
                                            <TextBlock Text="→" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                        </Border>
                                    </Grid>
                                </Button>

                                <TextBlock x:Name="TxtMensaje" Canvas.Left="0" Canvas.Top="344" Width="580" Height="30" Text="" Foreground="#B00020" FontSize="15" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap"/>

                                <!-- Nota informativa -->
                                <Border Canvas.Left="0" Canvas.Top="364" Width="580" Height="72" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E9EE" BorderThickness="1" Padding="20,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="14" BorderBrush="#007C78" BorderThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="i" FontSize="20" FontWeight="Bold" Foreground="#007C78" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="Ingrese los 10 dígitos de su cédula. El sistema registrará automáticamente el uso del equipo." FontSize="16" Foreground="#5F6C78" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Separador -->
                                <Grid Canvas.Left="-6" Canvas.Top="480" Width="592" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="230"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Height="1.2" Background="#D5DDE3" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Información de la estación" FontSize="16" Foreground="#68737F" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Height="1.2" Background="#D5DDE3" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Equipo -->
                                <Border Canvas.Left="0" Canvas.Top="526" Width="272" Height="92" Style="{StaticResource PremiumCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="54" Height="54" CornerRadius="15" Background="#E8F4F4" VerticalAlignment="Center">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE770;" FontSize="27" Foreground="#007C78" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                            <TextBlock Text="Equipo" FontSize="15" FontWeight="SemiBold" Foreground="#5F6C78"/>
                                            <TextBlock x:Name="TxtPc" Text="PC" FontSize="24" FontWeight="ExtraBold" Foreground="#0C272A" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Ubicación -->
                                <Border Canvas.Left="292" Canvas.Top="526" Width="288" Height="92" Style="{StaticResource PremiumCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="54" Height="54" CornerRadius="15" Background="#E8F4F4" VerticalAlignment="Center">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE707;" FontSize="29" Foreground="#007C78" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                            <TextBlock Text="Ubicación" FontSize="15" FontWeight="SemiBold" Foreground="#5F6C78"/>
                                            <TextBlock x:Name="TxtUbicacion" Text="Laboratorio 3A" FontSize="22" FontWeight="ExtraBold" Foreground="#0C272A" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- IP / MAC -->
                                <Border Canvas.Left="0" Canvas.Top="636" Width="580" Height="72" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E9EE" BorderThickness="1" Padding="20,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE968;" FontSize="28" Foreground="#007C78" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtDatosPc" Grid.Column="1" Text="IP: --      |      MAC: --" FontSize="18" FontWeight="ExtraBold" Foreground="#0C272A" TextAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </Canvas>

                            <!-- SESIÓN ACTIVA -->
                            <Grid x:Name="PanelSesion" Visibility="Collapsed" Width="840" Height="710" Canvas.Left="95" Canvas.Top="90">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="118"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="80"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                    <Border Background="#DDF2F2" CornerRadius="14" Padding="18,8" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✓" FontSize="20" FontWeight="ExtraBold" Foreground="#007C78" Margin="0,0,8,0"/>
                                            <TextBlock Text="SESIÓN HABILITADA" FontSize="16" FontWeight="ExtraBold" Foreground="#007C78"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="Sesión activa" FontSize="42" FontWeight="ExtraBold" Foreground="#102D30" TextAlignment="Center"/>
                                    <TextBlock x:Name="TxtUsuarioSesion" Text="Cédula: --" FontSize="18" FontWeight="SemiBold" Foreground="#68737F" TextAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.12*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="0.88*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource PremiumCard}" CornerRadius="14" Padding="24">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
                                                <Border Width="50" Height="50" CornerRadius="15" Background="#E8F4F4" Margin="0,0,13,0">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE916;" FontSize="24" Foreground="#007C78" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Control de tiempo" FontSize="18" FontWeight="ExtraBold" Foreground="#102D30"/>
                                                    <TextBlock Text="Registro activo del uso del equipo" FontSize="13" Foreground="#68737F"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtTiempoSesion" Grid.Row="1" Text="Tiempo de uso: 00:00:00" FontSize="26" FontWeight="ExtraBold" Foreground="#102D30" Margin="0,0,0,12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TxtInicioSesion" Grid.Row="2" Text="Hora inicio: --" FontSize="17" FontWeight="Bold" Foreground="#0C272A" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                            <Border Grid.Row="3" Background="#F3F8F8" BorderBrush="#D0DAE1" BorderThickness="1.2" CornerRadius="14" Padding="16" VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock x:Name="TxtFinInactividad" Text="Inactividad: 00:00 / 05:00" FontSize="17" FontWeight="ExtraBold" Foreground="#0C272A" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <TextBlock x:Name="TxtEstadoSesion" Text="Estado: computadora habilitada" FontSize="15" FontWeight="SemiBold" Foreground="#5F6C78" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource PremiumCard}" CornerRadius="14" Padding="22">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Estación actual" FontSize="24" FontWeight="ExtraBold" Foreground="#102D30" Margin="0,0,0,16"/>
                                            <Border Grid.Row="1" Background="#F3F8F8" BorderBrush="#D0DAE1" BorderThickness="1.2" CornerRadius="14" Padding="14" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Equipo" FontSize="14" FontWeight="SemiBold" Foreground="#5F6C78"/>
                                                    <TextBlock Text="{Binding Text, ElementName=TxtPc}" FontSize="22" FontWeight="ExtraBold" Foreground="#0C272A" Margin="0,3,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="2" Background="#F3F8F8" BorderBrush="#D0DAE1" BorderThickness="1.2" CornerRadius="14" Padding="14" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Ubicación" FontSize="14" FontWeight="SemiBold" Foreground="#5F6C78"/>
                                                    <TextBlock Text="{Binding Text, ElementName=TxtUbicacion}" FontSize="21" FontWeight="ExtraBold" Foreground="#0C272A" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="3" Background="#FBFCFD" BorderBrush="#D0DAE1" BorderThickness="1.2" CornerRadius="14" Padding="14" VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Red" FontSize="14" FontWeight="SemiBold" Foreground="#5F6C78" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding Text, ElementName=TxtDatosPc}" FontSize="13" FontWeight="ExtraBold" Foreground="#0C272A" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                    <Button x:Name="BtnUsarComputadora" Content="USAR COMPUTADORA" Style="{StaticResource SessionPrimaryButtonStyle}" Click="BtnUsarComputadora_Click"/>
                                    <Button x:Name="BtnCerrarSesionManual" Content="CERRAR SESIÓN" Style="{StaticResource DangerButtonStyle}" Width="180" Height="54" Margin="16,0,0,0" Click="BtnCerrarSesionManual_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Barra inferior -->
                            <Border Canvas.Left="36" Canvas.Top="852" Width="962" Height="1" Background="#D9E1E6" Opacity="0.95"/>
                            <Canvas Canvas.Left="696" Canvas.Top="872" Width="286" Height="38">
                                <Border Canvas.Left="0" Canvas.Top="0" Width="126" Height="38" Background="#FAFCFD" BorderBrush="#DFE7EB" BorderThickness="1" CornerRadius="12">
                                    <Grid Margin="10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE916;" FontSize="14" Foreground="#72808C" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtHora" Grid.Column="1" Text="--:--:--" FontSize="14" FontWeight="SemiBold" Foreground="#63717D" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                                <Border Canvas.Left="138" Canvas.Top="0" Width="148" Height="38" Background="#FAFCFD" BorderBrush="#DFE7EB" BorderThickness="1" CornerRadius="12">
                                    <Grid Margin="10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE787;" FontSize="14" Foreground="#72808C" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtFecha" Grid.Column="1" Text="-- / -- / ----" FontSize="14" FontWeight="SemiBold" Foreground="#63717D" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </Canvas>
                        </Canvas>
                    </Border>
                </Grid>
            </Border>
        </Viewbox>
    </Grid>
</Window>
