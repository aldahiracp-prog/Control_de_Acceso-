<Window x:Class="ControlLab.ClienteWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ControlLab"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="#0B302E"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <!-- COLORES INSTITUCIONALES -->
        <SolidColorBrush x:Key="Primary" Color="#1E5B59"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#0B302E"/>
        <SolidColorBrush x:Key="PrimaryMid" Color="#2B756F"/>
        <SolidColorBrush x:Key="PrimaryLight" Color="#EAF3F1"/>
        <SolidColorBrush x:Key="Surface" Color="#F8FBFA"/>
        <SolidColorBrush x:Key="Card" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMain" Color="#213C3A"/>
        <SolidColorBrush x:Key="TextSoft" Color="#6F7F7D"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#BDD4CF"/>
        <SolidColorBrush x:Key="Danger" Color="#8B0000"/>

        <!-- BOTÓN PRINCIPAL DEL LOGIN -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="Width" Value="340"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                BorderBrush="#2D6E69"
                                BorderThickness="1.2">
                            <Border.Effect>
                                <DropShadowEffect Color="#274946"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÓN VERDE DE SESIÓN ACTIVA -->
        <Style x:Key="SessionPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Width" Value="230"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                BorderBrush="#2D6E69"
                                BorderThickness="1.2">
                            <Border.Effect>
                                <DropShadowEffect Color="#274946"
                                                  BlurRadius="16"
                                                  ShadowDepth="0"
                                                  Opacity="0.28"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÓN ROJO -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                BorderBrush="#A30B0B"
                                BorderThickness="1.2">
                            <Border.Effect>
                                <DropShadowEffect Color="#5F0000"
                                                  BlurRadius="16"
                                                  ShadowDepth="0"
                                                  Opacity="0.24"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TARJETA PREMIUM -->
        <Style x:Key="PremiumCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BorderBrush" Value="#BDD4CF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- FONDO -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B302E" Offset="0"/>
                <GradientStop Color="#14504C" Offset="0.45"/>
                <GradientStop Color="#348B82" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- DECORACIÓN -->
        <Ellipse Width="540"
                 Height="540"
                 Fill="#12FFFFFF"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-190,-190,0,0"/>

        <Ellipse Width="420"
                 Height="420"
                 Fill="#10FFFFFF"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-140,-120"/>

        <TextBlock Text="S"
                   FontSize="520"
                   FontWeight="Bold"
                   Foreground="#08FFFFFF"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,-40,0,0"/>

        <!-- ESCALA GENERAL -->
        <Viewbox Stretch="Uniform">

            <Grid Width="1450" Height="800">

                <!-- CONTENEDOR PRINCIPAL -->
                <Border Width="1320"
                        Height="690"
                        CornerRadius="36"
                        Background="{StaticResource Surface}"
                        BorderBrush="#70FFFFFF"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,30">

                    <Border.Effect>
                        <DropShadowEffect Color="Black"
                                          BlurRadius="42"
                                          ShadowDepth="0"
                                          Opacity="0.38"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="500"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- PANEL IZQUIERDO -->
                        <Border Grid.Column="0"
                                CornerRadius="36,0,0,36"
                                Padding="32">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#0E3835" Offset="0"/>
                                    <GradientStop Color="#1E5B59" Offset="0.50"/>
                                    <GradientStop Color="#2E8179" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="235"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="70"/>
                                </Grid.RowDefinitions>

                                <!-- LOGO -->
                                <Border Grid.Row="0"
                                        Background="White"
                                        CornerRadius="30"
                                        Padding="8"
                                        ClipToBounds="True"
                                        Margin="10,0,-10,0">

                                    <Border.Effect>
                                        <DropShadowEffect Color="Black"
                                                          BlurRadius="20"
                                                          ShadowDepth="0"
                                                          Opacity="0.24"/>
                                    </Border.Effect>

                                    <Grid ClipToBounds="True">
                                        <Image Source="/Assets/logo_instituto.png"
                                               Stretch="UniformToFill"
                                               Margin="38,-98,38,14"/>
                                    </Grid>
                                </Border>

                                <!-- PANDA -->
                                <Grid Grid.Row="1">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="0,8,0,0">

                                        <Border Background="#16FFFFFF"
                                                CornerRadius="32"
                                                Padding="18"
                                                Width="210"
                                                Height="298">

                                            <Image Source="/Assets/panda.png"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Height="270"
                                                   Width="282"
                                                   Margin="-7,0,0,0"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- FRASE -->
                                <Border Grid.Row="2"
                                        Background="#18FFFFFF"
                                        CornerRadius="18"
                                        Padding="16"
                                        VerticalAlignment="Center">

                                    <TextBlock Text="Yo soy del INTESUD"
                                               FontSize="25"
                                               FontWeight="Bold"
                                               FontStyle="Italic"
                                               Foreground="White"
                                               TextAlignment="Center"
                                               Margin="24,0,24,0"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- PANEL DERECHO -->
                        <Border Grid.Column="1"
                                CornerRadius="0,36,36,0"
                                Background="{StaticResource Surface}">

                            <Grid Margin="54,38,54,36">

                                <!-- PANTALLA LOGIN -->
                                <Grid x:Name="PanelLogin">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="150"/>
                                        <RowDefinition Height="95"/>
                                        <RowDefinition Height="82"/>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="55"/>
                                        <RowDefinition Height="115"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- ENCABEZADO -->
                                    <StackPanel Grid.Row="0"
                                                HorizontalAlignment="Center">

                                        <Border Background="{StaticResource PrimaryLight}"
                                                CornerRadius="18"
                                                Padding="20,8"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,12">

                                            <TextBlock Text="CONTROL DE ACCESO"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource Primary}"/>
                                        </Border>

                                        <TextBlock Text="Uso de Computadoras"
                                                   FontSize="40"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Primary}"
                                                   TextAlignment="Center"/>

                                        <TextBlock Text="Laboratorios y biblioteca institucional"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSoft}"
                                                   TextAlignment="Center"
                                                   Margin="0,8,0,0"/>

                                        <Grid Width="620" Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Height="2"
                                                    Background="#BCD0CD"
                                                    VerticalAlignment="Center"/>

                                            <Border Grid.Column="2"
                                                    Height="2"
                                                    Background="#BCD0CD"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- INPUT CÉDULA -->
                                    <Border Grid.Row="1"
                                            Background="#FFFFFF"
                                            CornerRadius="24"
                                            BorderBrush="#B8D1CC"
                                            BorderThickness="2.4"
                                            Height="82"
                                            VerticalAlignment="Center"
                                            Padding="20,0">

                                        <Border.Effect>
                                            <DropShadowEffect Color="#507A75"
                                                              BlurRadius="18"
                                                              ShadowDepth="0"
                                                              Opacity="0.20"/>
                                        </Border.Effect>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="62"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="52"
                                                    Height="52"
                                                    Background="#EAF4F1"
                                                    BorderBrush="#C8DEDA"
                                                    BorderThickness="1.4"
                                                    CornerRadius="17"
                                                    VerticalAlignment="Center">

                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           Text="&#xE77B;"
                                                           FontSize="25"
                                                           Foreground="{StaticResource Primary}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <Grid Grid.Column="1">
                                                <TextBox x:Name="TxtCedula"
                                                         FontSize="31"
                                                         FontWeight="Bold"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Foreground="{StaticResource Primary}"
                                                         MaxLength="10"
                                                         VerticalContentAlignment="Center"
                                                         PreviewTextInput="TxtCedula_PreviewTextInput"/>

                                                <TextBlock x:Name="TxtPlaceholder"
                                                           Text="Ingrese su cédula"
                                                           FontSize="29"
                                                           FontWeight="SemiBold"
                                                           Foreground="#8B9F9B"
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- BOTÓN INGRESAR -->
                                    <Button x:Name="BtnIngresar"
                                            Grid.Row="2"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Click="BtnIngresar_Click"
                                            Margin="0,31,0,0"
                                            Grid.RowSpan="2">

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="↪"
                                                       FontSize="30"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="Ingresar"
                                                       FontSize="23"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- MENSAJE -->
                                    <TextBlock x:Name="TxtMensaje"
                                               Grid.Row="3"
                                               Text=""
                                               Foreground="#B00020"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>

                                    <!-- SEPARADOR -->
                                    <Grid Grid.Row="4"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Height="1.6"
                                                Background="#C8D8D5"
                                                VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Margin="18,0">

                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE946;"
                                                       FontSize="18"
                                                       Foreground="{StaticResource TextSoft}"
                                                       Margin="0,0,8,0"/>

                                            <TextBlock Text="Información de la estación"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSoft}"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Height="1.6"
                                                Background="#C8D8D5"
                                                VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- TARJETAS EQUIPO / UBICACIÓN -->
                                    <Grid Grid.Row="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- EQUIPO -->
                                        <Border Grid.Column="0"
                                                Style="{StaticResource PremiumCard}">

                                            <Border.Effect>
                                                <DropShadowEffect Color="#60706D"
                                                                  BlurRadius="15"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.16"/>
                                            </Border.Effect>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="68"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="56"
                                                        Height="56"
                                                        Background="#EAF4F1"
                                                        BorderBrush="#C8DEDA"
                                                        BorderThickness="1.3"
                                                        CornerRadius="18"
                                                        VerticalAlignment="Center">

                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE770;"
                                                               FontSize="26"
                                                               Foreground="{StaticResource Primary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">

                                                    <TextBlock Text="Equipo"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource Primary}"/>

                                                    <TextBlock x:Name="TxtPc"
                                                               Text="PC"
                                                               FontSize="29"
                                                               FontWeight="ExtraBold"
                                                               Foreground="{StaticResource Primary}"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- UBICACIÓN -->
                                        <Border Grid.Column="2"
                                                Style="{StaticResource PremiumCard}">

                                            <Border.Effect>
                                                <DropShadowEffect Color="#60706D"
                                                                  BlurRadius="15"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.16"/>
                                            </Border.Effect>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="68"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="56"
                                                        Height="56"
                                                        Background="#EAF4F1"
                                                        BorderBrush="#C8DEDA"
                                                        BorderThickness="1.3"
                                                        CornerRadius="18"
                                                        VerticalAlignment="Center">

                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE707;"
                                                               FontSize="26"
                                                               Foreground="{StaticResource Primary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">

                                                    <TextBlock Text="Ubicación"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource Primary}"/>

                                                    <TextBlock x:Name="TxtUbicacion"
                                                               Text="Laboratorio 3A"
                                                               FontSize="28"
                                                               FontWeight="ExtraBold"
                                                               Foreground="{StaticResource Primary}"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- IP Y MAC -->
                                    <Border Grid.Row="6"
                                            Background="#EEF6F4"
                                            BorderBrush="#BCD4CF"
                                            BorderThickness="2"
                                            CornerRadius="22"
                                            Padding="16"
                                            VerticalAlignment="Center">

                                        <Border.Effect>
                                            <DropShadowEffect Color="#406764"
                                                              BlurRadius="12"
                                                              ShadowDepth="0"
                                                              Opacity="0.14"/>
                                        </Border.Effect>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">

                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE968;"
                                                       FontSize="21"
                                                       Foreground="{StaticResource Primary}"
                                                       Margin="0,0,12,0"/>

                                            <TextBlock x:Name="TxtDatosPc"
                                                       Text="IP: -- | MAC: --"
                                                       FontSize="18"
                                                       FontWeight="ExtraBold"
                                                       Foreground="{StaticResource Primary}"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- NOTA -->
                                    <TextBlock Grid.Row="7"
                                               Text="Ingrese los 10 dígitos de su cédula. El sistema registrará automáticamente el uso del equipo."
                                               FontSize="14"
                                               Foreground="{StaticResource TextSoft}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="50,8,50,0"
                                               VerticalAlignment="Top"/>
                                </Grid>

                                <!-- PANTALLA SESIÓN ACTIVA -->
                                <Grid x:Name="PanelSesion"
                                      Visibility="Collapsed">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="115"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="72"/>
                                    </Grid.RowDefinitions>

                                    <!-- ENCABEZADO SESIÓN -->
                                    <StackPanel Grid.Row="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top"
                                                Margin="0,0,0,8">

                                        <Border Background="#E7F4F0"
                                                BorderBrush="#BDD7D1"
                                                BorderThickness="1.5"
                                                CornerRadius="22"
                                                Padding="20,9"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,8">

                                            <Border.Effect>
                                                <DropShadowEffect Color="#355C58"
                                                                  BlurRadius="10"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.14"/>
                                            </Border.Effect>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓"
                                                           FontSize="21"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{StaticResource Primary}"
                                                           Margin="0,0,8,0"/>

                                                <TextBlock Text="SESIÓN HABILITADA"
                                                           FontSize="16"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{StaticResource Primary}"/>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="Sesión activa"
                                                   FontSize="38"
                                                   FontWeight="ExtraBold"
                                                   Foreground="{StaticResource Primary}"
                                                   TextAlignment="Center"/>

                                        <TextBlock x:Name="TxtUsuarioSesion"
                                                   Text="Cédula: --"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Primary}"
                                                   TextAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- CONTENIDO SESIÓN -->
                                    <Grid Grid.Row="1"
                                          Margin="0,8,0,0">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.15*"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="0.85*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- TARJETA TIEMPO -->
                                        <Border Grid.Column="0"
                                                Style="{StaticResource PremiumCard}"
                                                Padding="24"
                                                CornerRadius="22">

                                            <Border.Effect>
                                                <DropShadowEffect Color="#60706D"
                                                                  BlurRadius="15"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.16"/>
                                            </Border.Effect>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0"
                                                            Orientation="Horizontal"
                                                            Margin="0,0,0,14">

                                                    <Border Width="48"
                                                            Height="48"
                                                            Background="#EAF4F1"
                                                            BorderBrush="#C8DEDA"
                                                            BorderThickness="1.3"
                                                            CornerRadius="16"
                                                            Margin="0,0,12,0">

                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE916;"
                                                                   FontSize="22"
                                                                   Foreground="{StaticResource Primary}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Control de tiempo"
                                                                   FontSize="17"
                                                                   FontWeight="ExtraBold"
                                                                   Foreground="{StaticResource Primary}"/>

                                                        <TextBlock Text="Registro activo del uso del equipo"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextSoft}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock x:Name="TxtTiempoSesion"
                                                           Grid.Row="1"
                                                           Text="Tiempo de uso: 00:00:00"
                                                           FontSize="27"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{StaticResource Primary}"
                                                           Margin="0,0,0,12"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock x:Name="TxtInicioSesion"
                                                           Grid.Row="2"
                                                           Text="Hora inicio: --"
                                                           FontSize="17"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource Primary}"
                                                           Margin="0,0,0,12"
                                                           TextWrapping="Wrap"/>

                                                <Border Grid.Row="3"
                                                        Background="#EEF6F4"
                                                        BorderBrush="#BCD4CF"
                                                        BorderThickness="1.6"
                                                        CornerRadius="18"
                                                        Padding="16"
                                                        VerticalAlignment="Top">

                                                    <StackPanel>
                                                        <TextBlock x:Name="TxtFinInactividad"
                                                                   Text="Inactividad: 00:00 / 05:00"
                                                                   FontSize="17"
                                                                   FontWeight="ExtraBold"
                                                                   Foreground="{StaticResource Primary}"
                                                                   Margin="0,0,0,8"
                                                                   TextWrapping="Wrap"/>

                                                        <TextBlock x:Name="TxtEstadoSesion"
                                                                   Text="Estado: computadora habilitada"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#5F7773"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- TARJETA ESTACIÓN -->
                                        <Border Grid.Column="2"
                                                Style="{StaticResource PremiumCard}"
                                                Padding="22"
                                                CornerRadius="22">

                                            <Border.Effect>
                                                <DropShadowEffect Color="#60706D"
                                                                  BlurRadius="15"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.16"/>
                                            </Border.Effect>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Text="Estación actual"
                                                           FontSize="25"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{StaticResource Primary}"
                                                           Margin="0,0,0,14"/>

                                                <Border Grid.Row="1"
                                                        Background="{StaticResource PrimaryLight}"
                                                        BorderBrush="#C8DEDA"
                                                        BorderThickness="1.2"
                                                        CornerRadius="16"
                                                        Padding="14"
                                                        Margin="0,0,0,12">

                                                    <StackPanel>
                                                        <TextBlock Text="Equipo"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource Primary}"/>

                                                        <TextBlock Text="{Binding Text, ElementName=TxtPc}"
                                                                   FontSize="23"
                                                                   FontWeight="ExtraBold"
                                                                   Foreground="{StaticResource Primary}"
                                                                   Margin="0,3,0,0"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="2"
                                                        Background="{StaticResource PrimaryLight}"
                                                        BorderBrush="#C8DEDA"
                                                        BorderThickness="1.2"
                                                        CornerRadius="16"
                                                        Padding="14"
                                                        Margin="0,0,0,12">

                                                    <StackPanel>
                                                        <TextBlock Text="Ubicación"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource Primary}"/>

                                                        <TextBlock Text="{Binding Text, ElementName=TxtUbicacion}"
                                                                   FontSize="22"
                                                                   FontWeight="ExtraBold"
                                                                   Foreground="{StaticResource Primary}"
                                                                   Margin="0,3,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="3"
                                                        Background="#EEF6F4"
                                                        BorderBrush="#BCD4CF"
                                                        BorderThickness="1.3"
                                                        CornerRadius="16"
                                                        Padding="14"
                                                        VerticalAlignment="Top">

                                                    <StackPanel>
                                                        <TextBlock Text="Red"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource Primary}"
                                                                   Margin="0,0,0,6"/>

                                                        <TextBlock Text="{Binding Text, ElementName=TxtDatosPc}"
                                                                   FontSize="13"
                                                                   FontWeight="ExtraBold"
                                                                   Foreground="{StaticResource Primary}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- BOTONES SESIÓN -->
                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom"
                                                Margin="0,10,0,0">

                                        <Button x:Name="BtnUsarComputadora"
                                                Content="USAR COMPUTADORA"
                                                Style="{StaticResource SessionPrimaryButtonStyle}"
                                                Click="BtnUsarComputadora_Click"/>

                                        <Button x:Name="BtnCerrarSesionManual"
                                                Content="CERRAR SESIÓN"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Width="180"
                                                Height="54"
                                                Margin="16,0,0,0"
                                                Click="BtnCerrarSesionManual_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- FOOTER -->
                <Grid VerticalAlignment="Bottom"
                      Margin="50,0,50,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text=""
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <StackPanel>
                            <TextBlock x:Name="TxtHora"
                                       Text="--:--"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Right"/>

                            <TextBlock x:Name="TxtFecha"
                                       Text="--/--/----"
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="18"
                               Foreground="White"
                               Margin="66,12,591,-12"/>

                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="18"
                               Foreground="White"
                               Margin="43,13,614,-13"/>
                </Grid>

            </Grid>
        </Viewbox>
    </Grid>
</Window>